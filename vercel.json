{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), payment=(self), interest-cohort=()" }
      ]
    },
    {
      "source": "/(|index\\.html|dashboard\\.html|privacy\\.html|terms\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag",  "value": "noindex, nofollow" }
      ]
    }
  ],
  "routes": [
    { "src": "/admin", "dest": "/dashboard.html" }
  ],
  "functions": {
    "api/meditation.js":     { "maxDuration": 90  },
    "api/audio.js":          { "maxDuration": 90  },
    "api/checkout.js":       { "maxDuration": 30  },
    "api/webhook.js":        { "maxDuration": 30  },
    "api/user.js":           { "maxDuration": 15  },
    "api/logs.js":           { "maxDuration": 15  },
    "api/health.js":         { "maxDuration": 10  },
    "api/admin.js":          { "maxDuration": 15  },
    "api/save-meditation.js":{ "maxDuration": 30  },
    "api/dashboard.js":      { "maxDuration": 30  },
    "api/buzon.js":          { "maxDuration": 15  }
  }
}
