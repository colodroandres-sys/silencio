# Copia este archivo como .env.local para desarrollo local
# En Vercel, añade estas variables en Settings → Environment Variables

ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# Rate limiting — requiere cuenta gratuita en upstash.com
# Sin estas variables el rate limiting queda desactivado (fail-open)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
